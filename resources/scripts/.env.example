# auto-install 环境变量配置文件模板
# 复制此文件为 .env 并修改相应的值，然后运行：
# source .env && sudo bash auto-install.sh

# ========== 必需的环境变量 ==========

# API 服务器地址
API_HOST="api.example.com"

# API 密钥（认证令牌）
API_KEY="your-secret-api-key-here"

# 节点 ID（必须是数字）
NODE_ID="1"

# 核心类型
# 1 = xray
# 2 = singbox (默认)
# 3 = hysteria2
CORE_TYPE="2"

# ========== 可选的环境变量 ==========

# 节点传输协议
# 1  = Shadowsocks
# 2  = Vless (默认)
# 3  = Vmess
# 4  = Hysteria
# 5  = Hysteria2
# 6  = Trojan
# 7  = Tuic
# 8  = AnyTLS
NODE_TYPE="2"

# 节点类型
# stand = 独立节点 (默认)
# in = 入站节点（需要设置 NODE_OUT_SERVER）
# out = 出站节点
NODE_INOUT_TYPE="stand"

# 出口节点服务器（仅当 NODE_INOUT_TYPE=in 时需要）
#NODE_OUT_SERVER="out-node.example.com:443"

# ========== 证书配置 ==========

# 证书模式
# none = 无 (默认)
# http = HTTP 自动申请
# dns = DNS 自动申请
# self = 自签证书
CERT_MODE="none"

# 证书域名
CERT_DOMAIN="www.apple.com"

# 自动配置生成选项==========

# 是否生成配置文件（y/n）
IF_GENERATE="y"

# 是否运行注册脚本（y/n）
# 需要 python3 支持
# 会自动从 Github 下载 register.py 并执行
IF_REGISTER="y"

# ========== Github 相关配置 ==========

# Github Token（可选，用于加快 API 调用和文件下载）
#GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"

# Release 仓库（默认）
RELEASE_REPO="Lawer09/ad2nx"

# 脚本仓库（默认）
SCRIPT_REPO="Lawer09/ad2nx-s"

# 脚本分支（默认）
SCRIPT_BRANCH="master"

# ========== 高级选项 ==========

#Reality 节点配置（仅当 NODE_TYPE=2/vless 时有效）
NODE_TYPE2="reality"

#UUID（Reality 节点使用）
UUID_AB="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

#SHORT_ID（Reality 节点使用）
SHORT_ID="xxxxxxxxxxxx"

#Reality 握手服务器（默认: www.apple.com）
REALITY_SERVER_NAME="www.apple.com"

# ========== 使用说明 ==========
# 1. 复制此文件为 .env
# 2. 按需修改相应的配置值
# 3. 运行命令：source .env && sudo bash auto-install.sh
# 
# 或者直接导入并运行：
# source .env && sudo bash auto-install.sh